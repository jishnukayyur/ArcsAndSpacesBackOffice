{
    "name":  "arcs-and-spaces-backoffice",
    "version":  "0.0.0",
    "scripts":  {
                    "ng":  "cmd /c \"set PATH=%CD%\\\\.binfix;%PATH% \u0026\u0026 ng\"",
                    "start":  "cmd /c \"set PATH=%CD%\\\\.binfix;%PATH% \u0026\u0026 ng serve --proxy-config proxy.conf.json\"",
                    "api":  "node server/server.js",
                    "dev":  "concurrently \"npm:start\" \"npm:api\"",
                    "build":  "cmd /c \"set PATH=%CD%\\\\.binfix;%PATH% \u0026\u0026 ng build\"",
                    "watch":  "cmd /c \"set PATH=%CD%\\\\.binfix;%PATH% \u0026\u0026 ng build --watch --configuration development\"",
                    "test":  "cmd /c \"set PATH=%CD%\\\\.binfix;%PATH% \u0026\u0026 ng test\"",
                    "postinstall":  "node scripts/patch-angular-cli.js"
                },
    "prettier":  {
                     "printWidth":  100,
                     "singleQuote":  true,
                     "overrides":  [
                                       {
                                           "files":  "*.html",
                                           "options":  {
                                                           "parser":  "angular"
                                                       }
                                       }
                                   ]
                 },
    "private":  true,
    "dependencies":  {
                         "@angular/common":  "^21.0.0",
                         "@angular/compiler":  "^21.0.0",
                         "@angular/core":  "^21.0.0",
                         "@angular/forms":  "^21.0.0",
                         "@angular/platform-browser":  "^21.0.0",
                         "@angular/router":  "^21.0.0",
                         "cors":  "^2.8.6",
                         "express":  "^5.2.1",
                         "multer":  "^2.1.1",
                         "rxjs":  "~7.8.0",
                         "tslib":  "^2.3.0"
                     },
    "devDependencies":  {
                            "@angular/build":  "^21.0.4",
                            "@angular/cli":  "^21.0.4",
                            "@angular/compiler-cli":  "^21.0.0",
                            "concurrently":  "^9.2.1",
                            "jsdom":  "^27.1.0",
                            "typescript":  "~5.9.2",
                            "vitest":  "^4.0.8"
                        }
}
